{
  "name": "cf-todo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --platform=browser --outfile=dist/worker.mjs --banner:js=\"/* eslint-disable */\"",
    "dev": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply todo-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply todo-db --remote"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.2",
    "ical.js": "2.2.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.4",
    "esbuild": "^0.24.0",
    "miniflare": "^3.20241218.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "wrangler": "^4.106.0"
  }
}
